{
  "name": "hms",
  "version": "1.0.0",
  "private": true,
  "description": "Hotel Management System monorepo",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "apps/shared"
  ],
  "scripts": {
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "dev:backend": "bun run --cwd apps/backend dev",
    "build:frontend": "bun run --cwd apps/frontend build",
    "typecheck:frontend": "bun run --cwd apps/frontend type-check"
  },
  "packageManager": "bun@1.2.13"
}
